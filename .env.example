# --- oh-beach Umgebungsvariablen ---
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Auf Vercel werden dieselben Variablen in den Project Settings hinterlegt.

# Sitzungs-Cookie (nuxt-auth-utils) – mind. 32 Zeichen, zufällig
NUXT_SESSION_PASSWORD=

# Secret zum Signieren der Einmal-Links (Passwort setzen/zurücksetzen)
NUXT_AUTH_TOKEN_SECRET=

# Google Service Account (Sheets + Calendar)
NUXT_GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private Key inkl. \n als echte Zeilenumbrüche ODER als ein-Zeiler mit \n
NUXT_GOOGLE_PRIVATE_KEY=
# ID des Mitglieder-Sheets (aus der Sheet-URL)
NUXT_GOOGLE_SHEET_ID=
# Tabellenblatt-Name (Standard: "Form responses 1")
NUXT_GOOGLE_SHEET_TAB=Form responses 1
# Tab für außerordentliche Mitglieder (Spalten: Vorname | Nachname | E-Mail).
# Standard: "Ausserordentliche Mitglieder" – dürfen sich einloggen und buchen.
NUXT_GOOGLE_SHEET_TAB_EXTRA=Ausserordentliche Mitglieder
# ID des Platzbelegungs-Kalenders (Kalender-Einstellungen -> Kalender-ID)
NUXT_GOOGLE_CALENDAR_ID=

# Resend (E-Mail-Versand für Passwort-Links)
NUXT_RESEND_API_KEY=
NUXT_EMAIL_FROM=no-reply@deine-domain.at

# Öffentliche Basis-URL (für Links in E-Mails)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
